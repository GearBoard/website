{
    "name": "gearboard-backend",
    "version": "1.0.0",
    "main": "src/index.ts",
    "license": "MIT",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node .",
        "check": "tsc --noEmit",
        "db.create": "docker-compose up -d db",
        "db.start": "docker-compose start db",
        "db.stop": "docker-compose stop db",
        "db.down": "docker-compose down",
        "db.generate": "npx prisma generate",
        "db.push": "npx prisma db push",
        "db.studio": "npx prisma studio",
        "db.migrate": "npx prisma migrate dev",
        "db.apply": "npx prisma migrate deploy",
        "db.seed": "tsx prisma/seed.ts",
        "db.reset": "npx prisma migrate reset"
    },
    "dependencies": {
        "@prisma/client": "^5.10.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.24",
        "prisma": "^5.10.2",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3"
    }
}
