{
  "info": {
    "name": "Gearboard API",
    "description": "API collection for Gearboard backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Get a user by id. Path param `id` must be a valid positive integer (e.g. 1)."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"USER\",\n  \"image\": \"https://example.com/avatar.png\",\n  \"description\": \"Engineering student\",\n  \"departmentId\": \"1\",\n  \"provider\": \"LOCAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Create a new user. Required: username, email. Optional: password, role (USER | ADMIN, default USER), image, description, departmentId (string or number), provider (LOCAL | GOOGLE, default LOCAL)."
          }
        },
        {
          "name": "Create User (minimal)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"minimaluser\",\n  \"email\": \"minimal@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Create user with only required fields (username, email). password, role, image, description, departmentId, provider are optional (role defaults to USER)."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Simple health check."
          }
        }
      ]
    }
  ]
}
