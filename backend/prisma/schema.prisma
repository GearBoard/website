// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// USER
//////////////////////////

model User {
  id          BigInt     @id @default(autoincrement())
  username    String     @unique
  email       String     @unique
  password    String?    // null if login via Google
  image       String?    // profile picture
  description String?
  role        UserRole   @default(USER)
  departmentId BigInt?
  provider    AuthProvider @default(LOCAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  posts      Post[]
  comments   Comment[]
  likes      Like[]
  bookmarks  Bookmark[]
  department Department? @relation(fields: [departmentId], references: [id])
}

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

//////////////////////////
// DEPARTMENT
//////////////////////////

model Department {
  id   BigInt @id @default(autoincrement())
  name String

  users User[]
}

//////////////////////////
// POST (QUESTION)
//////////////////////////

model Post {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  title       String
  description String   @db.Text
  isClosed    Boolean  @default(false)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user      User        @relation(fields: [userId], references: [id])
  tags      PostTag[]
  images    PostImage[]
  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]
}

//////////////////////////
// POST IMAGES
//////////////////////////

model PostImage {
  id      BigInt @id @default(autoincrement())
  postId  BigInt
  url     String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

//////////////////////////
// TAG
//////////////////////////

model Tag {
  id    BigInt @id @default(autoincrement())
  name  String @unique

  posts PostTag[]
}

model PostTag {
  postId BigInt
  tagId  BigInt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
}

//////////////////////////
// COMMENT (supports reply)
//////////////////////////

model Comment {
  id        BigInt   @id @default(autoincrement())
  postId    BigInt
  userId    BigInt
  parentId  BigInt?  // for reply(can be null)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id])
  parent Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  images CommentImage[]
}

//////////////////////////
// COMMENT IMAGE
//////////////////////////

model CommentImage {
  id        BigInt @id @default(autoincrement())
  commentId BigInt
  url       String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

//////////////////////////
// LIKE
//////////////////////////

model Like {
  userId BigInt
  postId BigInt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

//////////////////////////
// BOOKMARK
//////////////////////////

model Bookmark {
  userId BigInt
  postId BigInt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}