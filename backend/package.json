{
  "name": "gearboard-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node .",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db.create": "docker-compose up -d db",
    "db.start": "docker-compose start db",
    "db.stop": "docker-compose stop db",
    "db.down": "docker-compose down",
    "db.generate": "npx prisma generate",
    "db.push": "npx prisma db push",
    "db.studio": "npx prisma studio",
    "db.migrate": "npx prisma migrate dev",
    "db.apply": "npx prisma migrate deploy",
    "db.seed": "tsx prisma/seed.ts",
    "db.reset": "npx prisma migrate reset"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "pg": "^8.13.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/yamljs": "^0.2.31",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "prisma": "^7.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.15.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
