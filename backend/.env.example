# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
# Set this to your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/gearboard?schema=public"

# Authentication Configuration
# Generate a random secret for BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGIN=http://localhost:3000

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=